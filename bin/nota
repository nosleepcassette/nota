#!/usr/bin/env python3
# maps · cassette.help · MIT
"""
nota — intelligent task CLI backed by taskwarrior

Commands:
  nota setup                            Install UDAs and contexts into ~/.taskrc
  nota add "text [inline syntax]"       Add task(s) — parses -> and :: syntax
  nota list [--project X] [--scope X]  List pending tasks grouped by project
  nota next                             Most urgent actionable tasks
  nota blocked                          Tasks blocked by unfinished dependencies
  nota show ID                          Full task detail
  nota done ID                          Mark task complete
  nota depend ID --on ID2               ID depends on ID2 (ID2 is prerequisite)
  nota annotate ID "note"               Add a note to a task
  nota projects                         Projects with task counts
  nota braindump "text" [--model ALIAS] [--dry-run]  LLM-parse → tasks
  nota log "habit"                      Log countable habit (multiple per day, e.g. cigarettes)
  nota mcp                              Start MCP stdio server

Inline syntax (used in `nota add`):
  ->   prerequisite:  "reply to pick n pull -> find stamps"
       (cannot complete left until right is done)
  ::   related-to:    "task A :: task B"
  p1–p4               priority (p1/p2 → H, p3 → M, p4 → L)
  @project            project assignment
  #tag                add tag
  scope:X             scope (meatspace/digital/server/etc.)
  due:DATE            due date (taskwarrior natural language: today/eow/friday/etc.)
"""

import argparse
import json
import os
import sys
from pathlib import Path

_ROOT = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(_ROOT))

from src.parse import parse_inline
from src.tw import (
    task_add, task_get, task_list, task_next, task_blocked,
    task_done, task_depend, task_annotate, task_projects,
    task_modify, fmt_row, fmt_detail, _run, _run_json,
)
from src.scopes import list_scopes, add_scope as scope_add, rm_scope as scope_rm


# ── commands ──────────────────────────────────────────────────────────────────

def cmd_setup(args):
    print("Setting up nota UDAs and contexts...")
    from src.setup import run_setup
    run_setup(verbose=True)


def cmd_add(args):
    parsed = parse_inline(args.title)

    # Map p-priority to tw priority
    pri = parsed["priority"]
    pri_p = f"p{pri}"
    
    # Handle recurrence aliases
    recur = args.recur
    until = args.until
    if recur:
        recur_map = {
            "daily": "daily", "weekly": "weekly", "biweekly": "biweekly",
            "monthly": "monthly", "quarterly": "quarterly", "annual": "annual"
        }
        if recur in recur_map:
            recur = recur_map[recur]
        # Recurring tasks need a due date
        if not parsed["due_date"] and not args.due:
            print("Recurring tasks require a due date. Use due:DATE in title or --due flag.", file=sys.stderr)
            sys.exit(1)
    
    # Parse NL dates for wait/scheduled
    from src.dateparse import parse_date
    wait = parse_date(args.wait) if args.wait else None
    scheduled = parse_date(args.scheduled) if args.scheduled else None
    until_date = parse_date(until) if until else None

    # Create the main task
    task = task_add(
        description=parsed["title"],
        project=parsed["project"] if parsed["project"] != "inbox" else None,
        priority_p=pri_p,
        due=parsed["due_date"],
        tags=parsed["tags"],
        scope=parsed["scope"] or None,
        body=args.body or None,
        recur=recur,
        until=until_date,
        wait=wait,
        scheduled=scheduled,
    )
    main_id = task.get("id")

    created = [main_id] if main_id else []
    dep_ids = []

    # Create subtasks (prerequisites) and link depends
    for sub_title in parsed["subtasks"]:
        sub_parsed = parse_inline(sub_title)
        sub_task = task_add(
            description=sub_parsed["title"],
            project=(sub_parsed["project"] if sub_parsed["project"] != "inbox"
                     else (parsed["project"] if parsed["project"] != "inbox" else None)),
            priority_p=f"p{sub_parsed['priority']}",
            due=sub_parsed["due_date"],
            scope=sub_parsed["scope"] or parsed["scope"] or None,
        )
        sub_id = sub_task.get("id")
        if sub_id:
            created.append(sub_id)
            dep_ids.append(sub_id)

    # Set dependencies on main task (main depends on all subs)
    if main_id and dep_ids:
        _run(str(main_id), "modify", f"depends:{','.join(str(i) for i in dep_ids)}")

    # Handle related_to — create/find and annotate both sides
    for rel_title in parsed["related_titles"]:
        # Try to find existing task by description match
        all_tasks = task_list(status="pending", limit=500)
        existing = next(
            (t for t in all_tasks if rel_title.lower() in t.get("description", "").lower()),
            None
        )
        if existing:
            rel_id = existing["id"]
        else:
            rel_task = task_add(
                description=rel_title,
                project=parsed["project"] if parsed["project"] != "inbox" else None,
            )
            rel_id = rel_task.get("id")
            if rel_id:
                created.append(rel_id)

        if main_id and rel_id:
            task_annotate(main_id, f"related: [{rel_id}] {rel_title}")
            task_annotate(rel_id, f"related: [{main_id}] {parsed['title']}")

    if args.json:
        print(json.dumps({"created": created, "main_id": main_id}))
    else:
        t = task_get(main_id) if main_id else None
        if t:
            print(f"Added [{main_id}] {t['description']}")
        if len(created) > 1:
            print(f"  + {len(created)-1} linked task(s): {created[1:]}")


def cmd_list(args):
    tasks = task_list(
        project=args.project,
        scope=args.scope,
        priority_p=f"p{args.priority}" if args.priority else None,
        status="pending",
    )
    if args.json:
        print(json.dumps(tasks))
        return
    if not tasks:
        print("No tasks.")
        return
    by_project: dict = {}
    for t in tasks:
        proj = t.get("project") or "inbox"
        by_project.setdefault(proj, []).append(t)
    for proj in sorted(by_project):
        print(f"\n── {proj} ──")
        for t in by_project[proj]:
            print(fmt_row(t))


def cmd_next(args):
    tasks = task_next(limit=args.limit)
    if args.json:
        print(json.dumps(tasks))
        return
    if not tasks:
        print("Nothing ready.")
        return
    print("\n── next (by urgency) ──")
    for t in tasks:
        print(fmt_row(t))


def cmd_blocked(args):
    tasks = task_blocked()
    if args.json:
        print(json.dumps(tasks))
        return
    if not tasks:
        print("Nothing blocked.")
        return
    print("\n── blocked ──")
    for t in tasks:
        print(fmt_row(t))


def cmd_show(args):
    t = task_get(args.id)
    if not t:
        print(f"Task {args.id} not found.", file=sys.stderr)
        sys.exit(1)
    if args.json:
        print(json.dumps(t))
    else:
        print(fmt_detail(t))


def cmd_done(args):
    """Mark task(s) complete."""
    # Handle bulk IDs
    ids = []
    if hasattr(args, 'ids') and args.ids:
        ids = args.ids
    elif hasattr(args, 'id') and args.id:
        ids = [args.id]
    
    # Handle --project, --scope, --filter flags
    if args.project or args.scope or args.filter:
        tasks = task_list(
            project=args.project,
            scope=args.scope,
            status="pending",
            extra_filter=args.filter,
            limit=500,
        )
        ids = [t["id"] for t in tasks]
    
    if not ids:
        print("No tasks specified.", file=sys.stderr)
        sys.exit(1)
    
    results = []
    for task_id in ids:
        ok = task_done(task_id)
        results.append((task_id, ok))
    
    success = sum(1 for _, ok in results if ok)
    print(f"Completed {success}/{len(results)} task(s)")
    for task_id, ok in results:
        if ok:
            print(f"  ✓ [{task_id}]")
        else:
            print(f"  ✗ [{task_id}]")


def cmd_edit(args):
    """Edit an existing task."""
    task_id = args.id
    updates = {}
    
    if args.title:
        updates["description"] = args.title
    if args.project:
        updates["project"] = args.project
    if args.priority:
        updates["priority_p"] = f"p{args.priority}"
    if args.due:
        from src.dateparse import parse_date
        updates["due"] = parse_date(args.due) or args.due
    if args.scope:
        updates["scope"] = args.scope
    if args.add_tag:
        updates.setdefault("tags_add", []).append(args.add_tag)
    if args.rm_tag:
        updates.setdefault("tags_remove", []).append(args.rm_tag)
    if args.body:
        task_annotate(task_id, args.body)
    
    if updates:
        result = task_modify(task_id, **updates)
        if result:
            t = task_get(task_id)
            if t and args.json:
                print(json.dumps(t))
            elif t:
                print(f"Updated [{task_id}] {t['description']}")
        else:
            print(f"Failed to update task {task_id}.", file=sys.stderr)
            sys.exit(1)
    else:
        t = task_get(task_id)
        if t and args.json:
            print(json.dumps(t))
        elif t:
            print(fmt_detail(t))
        else:
            print(f"Task {task_id} not found.", file=sys.stderr)
            sys.exit(1)


def cmd_scopes(args):
    """List or manage scopes."""
    if args.add:
        ok = scope_add(args.add, args.emoji, args.description)
        if ok:
            print(f"Added scope: {args.add}")
        else:
            print(f"Scope '{args.add}' already exists or is a default.", file=sys.stderr)
            sys.exit(1)
    elif args.remove:
        ok = scope_rm(args.remove)
        if ok:
            print(f"Removed scope: {args.remove}")
        else:
            print(f"Scope '{args.remove}' not found or is a default.", file=sys.stderr)
            sys.exit(1)
    else:
        scopes = list_scopes()
        if args.json:
            print(json.dumps(scopes))
            return
        print("\n── scopes ──────────────────────────")
        for s in sorted(scopes, key=lambda x: x["name"]):
            emoji = s["emoji"] or "  "
            print(f"  {emoji}  {s['name']:<14} {s['description']}")
        print()


def cmd_move(args):
    """Move task(s) to another project."""
    ids = args.ids
    project = args.project
    
    results = []
    for task_id in ids:
        ok = task_modify(task_id, project=project)
        results.append((task_id, bool(ok)))
    
    success = sum(1 for _, ok in results if ok)
    print(f"Moved {success}/{len(results)} task(s) to @{project}")
    for task_id, ok in results:
        print(f"  {'✓' if ok else '✗'} [{task_id}]")


def cmd_tag(args):
    """Add/remove tags from task(s)."""
    ids = args.ids
    tags_add = args.add or []
    tags_rm = args.rm or []
    
    if not tags_add and not tags_rm:
        print("No tags specified. Use --add or --rm.", file=sys.stderr)
        sys.exit(1)
    
    results = []
    for task_id in ids:
        ok = task_modify(task_id, tags_add=tags_add, tags_remove=tags_rm)
        results.append((task_id, bool(ok)))
    
    success = sum(1 for _, ok in results if ok)
    print(f"Tagged {success}/{len(results)} task(s)")
    for task_id, ok in results:
        print(f"  {'✓' if ok else '✗'} [{task_id}]")


def cmd_depend(args):
    """Set dependency: task ID depends on task ID2."""
    ok = task_depend(args.id, args.on)
    if ok:
        print(f"[{args.id}] now depends on [{args.on}]")
    else:
        print("Failed to set dependency.", file=sys.stderr)
        sys.exit(1)


def cmd_relate(args):
    """Create relations between tasks using tags."""
    task_id = args.id
    target_id = args.to or args.blocks or args.subtask
    
    if not target_id:
        print("Specify --to, --blocks, or --subtask.", file=sys.stderr)
        sys.exit(1)
    
    if args.to:
        rel_type = "related"
    elif args.blocks:
        rel_type = "blocks"
    elif args.subtask:
        rel_type = "subtask"
    
    # Add tag to source task
    ok1 = task_modify(task_id, tags_add=[f"related:{target_id}"])
    
    # Add reverse tag to target task
    ok2 = task_modify(target_id, tags_add=[f"related:{task_id}"])
    
    if ok1 and ok2:
        print(f"Created {rel_type} relation: [{task_id}] ↔ [{target_id}]")
    else:
        print(f"Failed to create relation.", file=sys.stderr)
        sys.exit(1)


def cmd_related(args):
    """Show tasks related to a given task."""
    task_id = args.id
    t = task_get(task_id)
    
    if not t:
        print(f"Task {task_id} not found.", file=sys.stderr)
        sys.exit(1)
    
    tags = t.get("tags", [])
    related_ids = []
    for tag in tags:
        if tag.startswith("related:"):
            try:
                related_ids.append(int(tag.split(":")[1]))
            except:
                pass
    
    if not related_ids:
        print(f"No related tasks for [{task_id}]")
        return
    
    print(f"\n── related to [{task_id}] ─────────────────")
    for rid in related_ids:
        rt = task_get(rid)
        if rt:
            status = "✓" if rt.get("status") == "completed" else " "
            print(f"  [{rid}] {status} {rt.get('description','')}")
    print()


def cmd_tree(args):
    """Show dependency tree for a task."""
    task_id = args.id
    
    def get_depends(tid):
        t = task_get(tid)
        if not t:
            return []
        return t.get("depends", [])
    
    def render_tree(tid, prefix="", is_last=True):
        t = task_get(tid)
        if not t:
            return []
        
        status = "✓" if t.get("status") == "completed" else "○"
        desc = t.get("description", "")[:50]
        line = f"{prefix}[{tid}] {status} {desc}"
        lines = [line]
        
        deps = get_depends(tid)
        new_prefix = prefix + ("    " if is_last else "│   ")
        
        for i, dep_uuid in enumerate(deps):
            # Look up UUID to get ID
            found = _run_json(f"uuid:{dep_uuid}", "export")
            if found:
                dep_id = found[0].get("id")
                is_last_dep = (i == len(deps) - 1)
                connector = "└── " if is_last_dep else "├── "
                lines.extend(render_tree(dep_id, new_prefix + connector, is_last_dep))
        
        return lines
    
    print(f"\n── dependency tree for [{task_id}] ────────────")
    lines = render_tree(task_id, "", True)
    for line in lines:
        print(line)
    print()


def cmd_annotate(args):
    ok = task_annotate(args.id, args.note)
    if ok:
        print(f"Annotated [{args.id}]")
    else:
        print("Failed to annotate.", file=sys.stderr)
        sys.exit(1)


def cmd_projects(args):
    projects = task_projects()
    if args.json:
        print(json.dumps(projects))
        return
    if not projects:
        print("No open tasks.")
        return
    for p in projects:
        print(f"  {p['project']:<24} {p['count']} task(s)")


def cmd_recurring(args):
    """List recurring task parents."""
    tasks = _run_json("status:recurring", "export")
    if args.json:
        print(json.dumps(tasks))
        return
    if not tasks:
        print("No recurring tasks.")
        return
    print("\n── recurring ─────────────────────────")
    for t in tasks:
        recur = t.get("recur", "")
        print(f"  [{t['id']}] {t['description']:<40} recur:{recur}")
    print()


def cmd_waiting(args):
    """List waiting/hidden tasks."""
    tasks = task_list(status="waiting", limit=100)
    if args.json:
        print(json.dumps(tasks))
        return
    if not tasks:
        print("No waiting tasks.")
        return
    print("\n── waiting ────────────────────────────")
    for t in tasks:
        wait = t.get("wait", "")[:10] if t.get("wait") else ""
        print(f"  [{t['id']}] {t['description']:<40} wait:{wait}")
    print()


def cmd_braindump(args):
    from src.braindump import braindump
    braindump(args.text, model=args.model or None, dry_run=args.dry_run, verbose=True)


def cmd_track(args):
    """Record a habit as done (or n/s) for today."""
    from src.harsh import add_habit, log_habit, habit_names
    name = args.habit
    result = args.result
    if name not in habit_names():
        add_habit(name, frequency="0")
        print(f"New habit: {name}")
    written = log_habit(name, result=result, comment=args.note or "")
    glyphs = {"y": "✓", "n": "✗", "s": "~"}
    if written:
        print(f"{glyphs.get(result,'?')}  {name}")
    else:
        print(f"Already logged '{name}' today.")


def cmd_habits(args):
    """Show today's habit status. Falls back to harsh CLI if available."""
    import subprocess as _sp
    from src.harsh import habit_names, today_results
    import datetime as _dt

    names = habit_names()
    if not names:
        print("No habits configured. Edit ~/.config/harsh/habits")
        return

    done = today_results()

    if args.json:
        print(json.dumps([{"name": n, "result": done.get(n)} for n in names]))
        return

    # Try harsh log --json for richer data, fall back to simple display
    richer = None
    try:
        r = _sp.run(["harsh", "log", "--json"], capture_output=True, text=True, timeout=5)
        if r.returncode == 0:
            richer = {h["name"]: h for h in __import__("json").loads(r.stdout).get("habits", [])}
    except Exception:
        pass

    today = _dt.date.today()
    print(f"\n── habits · {today} ──────────────────────────")
    print(f"  {'':3}  {'habit':<28}  {'freq':<6}  streak  last")
    print(f"  {'─'*3}  {'─'*28}  {'─'*6}  {'─'*6}  {'─'*10}")
    glyphs = {"y": "✓", "n": "✗", "s": "~", None: "○"}
    for name in names:
        result = done.get(name)
        glyph = glyphs.get(result, "○")
        if richer and name in richer:
            h = richer[name]
            streak = h.get("current_streak", 0) or 0
            freq = str(h.get("frequency", "?"))
            lc = h.get("last_completed", "")
            last = lc[:10] if lc else "never"
        else:
            streak = ""
            freq = ""
            last = "today" if result else ""
        print(f"  {glyph:3}  {name:<28}  {freq:<6}  {str(streak):<6}  {last}")
    print()


def cmd_log(args):
    """Log a countable habit instance — multiple per day allowed."""
    from src.harsh import log_habit_count
    count = log_habit_count(args.habit, comment=args.note or "")
    print(f"✓  {args.habit}  (×{count} today)")


def cmd_mcp(args):
    try:
        from src.mcp_server import run
        run()
    except ImportError:
        print("MCP server not yet implemented. See CHANGELOG.md Step 4.", file=sys.stderr)
        sys.exit(1)


def cmd_find(args):
    """Advanced search/filter."""
    from src.query import build_filter
    
    filters = build_filter(
        project=args.project,
        scope=args.scope,
        priority=args.priority,
        status=args.status,
        overdue=args.overdue,
        due_this_week=args.due_this_week,
        has_annotation=args.has_annotation,
        unblocked=args.unblocked,
        extra=args.expression,
    )
    
    extra = " ".join(filters) if filters else ""
    
    tasks = task_list(
        project=args.project,
        scope=args.scope,
        priority_p=f"p{args.priority}" if args.priority else None,
        status=args.status or "pending",
        extra_filter=extra,
        limit=args.limit,
    )
    
    if args.json:
        print(json.dumps(tasks))
        return
    
    if not tasks:
        print("No tasks found.")
        return
    
    by_project: dict = {}
    for t in tasks:
        proj = t.get("project") or "inbox"
        by_project.setdefault(proj, []).append(t)
    for proj in sorted(by_project):
        print(f"\n── {proj} ──")
        for t in by_project[proj]:
            print(fmt_row(t))


# ── CLI wiring ────────────────────────────────────────────────────────────────

def main():
    parser = argparse.ArgumentParser(
        prog="nota",
        description="nota — intelligent task management backed by taskwarrior",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    sub = parser.add_subparsers(dest="cmd", required=True)

    sub.add_parser("setup", help="Install UDAs and contexts into ~/.taskrc (run once)")

    p_add = sub.add_parser("add", help='Add task(s). Supports -> and :: syntax.')
    p_add.add_argument("title", help='"task title [p1] [@proj] [#tag] [scope:X] [due:DATE] [-> prereq] [:: related]"')
    p_add.add_argument("--body", default="", help="Notes (added as annotation)")
    p_add.add_argument("--json", action="store_true")
    p_add.add_argument("--recur", help="Recurrence (daily, weekly, biweekly, monthly, quarterly, annual)")
    p_add.add_argument("--until", help="Recurrence end date")
    p_add.add_argument("--wait", help="Wait until date (hidden until)")
    p_add.add_argument("--scheduled", help="Scheduled date (actionable after)")

    p_list = sub.add_parser("list", help="List pending tasks")
    p_list.add_argument("--project", default=None)
    p_list.add_argument("--scope", default=None)
    p_list.add_argument("--priority", type=int, default=None, choices=[1,2,3,4])
    p_list.add_argument("--json", action="store_true")

    p_next = sub.add_parser("next", help="Most urgent actionable tasks")
    p_next.add_argument("--limit", type=int, default=20)
    p_next.add_argument("--json", action="store_true")

    p_blocked = sub.add_parser("blocked", help="Tasks blocked by unfinished prerequisites")
    p_blocked.add_argument("--json", action="store_true")

    p_show = sub.add_parser("show", help="Full task detail")
    p_show.add_argument("id", type=int)
    p_show.add_argument("--json", action="store_true")

    p_done = sub.add_parser("done", help="Mark task(s) complete")
    p_done.add_argument("ids", nargs="*", type=int, help="Task ID(s) to complete")
    p_done.add_argument("--project", help="Complete all in project")
    p_done.add_argument("--scope", help="Complete all in scope")
    p_done.add_argument("--filter", help="Raw taskwarrior filter expression")

    p_move = sub.add_parser("move", help="Move task(s) to project")
    p_move.add_argument("ids", nargs="+", type=int, help="Task ID(s)")
    p_move.add_argument("--project", required=True, help="Target project")

    p_tag = sub.add_parser("tag", help="Add/remove tags from task(s)")
    p_tag.add_argument("ids", nargs="+", type=int, help="Task ID(s)")
    p_tag.add_argument("--add", action="append", help="Tag to add (can repeat)")
    p_tag.add_argument("--rm", action="append", help="Tag to remove (can repeat)")

    p_edit = sub.add_parser("edit", help="Edit an existing task")
    p_edit.add_argument("id", type=int, help="Task ID to edit")
    p_edit.add_argument("--title", default=None, help="New title")
    p_edit.add_argument("--project", default=None, help="Change project")
    p_edit.add_argument("--priority", type=int, choices=[1,2,3,4], help="Priority (1-4)")
    p_edit.add_argument("--due", default=None, help="Due date (NL supported)")
    p_edit.add_argument("--scope", default=None, help="Scope")
    p_edit.add_argument("--add-tag", default=None, help="Add a tag")
    p_edit.add_argument("--rm-tag", default=None, help="Remove a tag")
    p_edit.add_argument("--body", default=None, help="Add note/annotation")
    p_edit.add_argument("--json", action="store_true")

    p_scopes = sub.add_parser("scopes", help="List or manage scopes")
    p_scopes.add_argument("--add", metavar="NAME", help="Add a custom scope")
    p_scopes.add_argument("--emoji", help="Emoji for --add")
    p_scopes.add_argument("--description", help="Description for --add")
    p_scopes.add_argument("--remove", metavar="NAME", help="Remove a custom scope")
    p_scopes.add_argument("--json", action="store_true")

    p_dep = sub.add_parser("depend", help="Set dependency: ID depends on ID2")
    p_dep.add_argument("id", type=int)
    p_dep.add_argument("--on", type=int, required=True, metavar="ID2", help="Prerequisite task ID")

    p_relate = sub.add_parser("relate", help="Create relation between tasks")
    p_relate.add_argument("id", type=int, help="Source task ID")
    p_relate.add_argument("--to", type=int, help="Related task ID")
    p_relate.add_argument("--blocks", type=int, help="Task ID that this blocks")
    p_relate.add_argument("--subtask", type=int, help="Subtask ID")

    p_related = sub.add_parser("related", help="Show related tasks")
    p_related.add_argument("id", type=int, help="Task ID")

    p_tree = sub.add_parser("tree", help="Show dependency tree")
    p_tree.add_argument("id", type=int, help="Task ID")

    # Recurring commands
    p_recur = sub.add_parser("recurring", help="List recurring tasks")
    p_recur.add_argument("--json", action="store_true")

    p_waiting = sub.add_parser("waiting", help="List waiting tasks")
    p_waiting.add_argument("--json", action="store_true")

    p_ann = sub.add_parser("annotate", help="Add a note to a task")
    p_ann.add_argument("id", type=int)
    p_ann.add_argument("note")

    p_proj = sub.add_parser("projects", help="Projects with task counts")
    p_proj.add_argument("--json", action="store_true")

    p_bd = sub.add_parser("braindump", help="LLM-parse freeform text into tasks")
    p_bd.add_argument("text", help="Freeform brain dump")
    p_bd.add_argument("--model", default=None, help="Model alias (see src/braindump.py MODELS)")
    p_bd.add_argument("--dry-run", action="store_true", help="Print parsed JSON without inserting")

    p_track = sub.add_parser("track", help="Record a habit as done today (y/n/s)")
    p_track.add_argument("habit", help="Habit name (auto-created if new)")
    p_track.add_argument("--result", "-r", default="y", choices=["y", "n", "s"])
    p_track.add_argument("--note", "-m", default="", help="Optional comment")

    # 'did' is natural-language alias for 'track --result y'
    p_log = sub.add_parser("log", help='Log a countable habit (multiple per day): nota log "smoked cigarette"')
    p_log.add_argument("habit", help="Habit name")
    p_log.add_argument("--note", default="", help="Optional note")

    p_did = sub.add_parser("did", help='Alias: nota did "watered plants" → track as done')
    p_did.add_argument("habit")
    p_did.add_argument("--note", "-m", default="")

    p_hb = sub.add_parser("habits", help="Show today's habit status")
    p_hb.add_argument("--json", action="store_true")

    p_find = sub.add_parser("find", help="Advanced search/filter")
    p_find.add_argument("--project")
    p_find.add_argument("--scope")
    p_find.add_argument("--priority", type=int, choices=[1,2,3,4])
    p_find.add_argument("--status", default="pending", help="Status filter (default: pending)")
    p_find.add_argument("--overdue", action="store_true", help="Due before today")
    p_find.add_argument("--due-this-week", action="store_true", help="Due by end of week")
    p_find.add_argument("--has-annotation", action="store_true", help="Has notes")
    p_find.add_argument("--unblocked", action="store_true", help="Not blocked")
    p_find.add_argument("--limit", type=int, default=50)
    p_find.add_argument("expression", nargs="?", help="Raw taskwarrior expression")
    p_find.add_argument("--json", action="store_true")

    sub.add_parser("mcp", help="Start MCP stdio server")

    args = parser.parse_args()
    {
        "setup":    cmd_setup,
        "add":      cmd_add,
        "list":     cmd_list,
        "next":     cmd_next,
        "blocked":  cmd_blocked,
        "show":     cmd_show,
        "done":     cmd_done,
        "edit":     cmd_edit,
        "move":     cmd_move,
        "tag":      cmd_tag,
        "scopes":   cmd_scopes,
        "find":     cmd_find,
        "depend":   cmd_depend,
        "relate":   cmd_relate,
        "related":  cmd_related,
        "tree":     cmd_tree,
        "annotate": cmd_annotate,
        "projects":   cmd_projects,
        "recurring": cmd_recurring,
        "waiting":   cmd_waiting,
        "braindump":  cmd_braindump,
        "track":      cmd_track,
        "log":        cmd_log,
        "did":        lambda a: cmd_track(type("A", (), {"habit": a.habit, "result": "y", "note": a.note})()),
        "habits":     cmd_habits,
        "mcp":        cmd_mcp,
    }[args.cmd](args)


if __name__ == "__main__":
    main()
